{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npm ci)",
      "Bash(npx tauri *)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx prettier*)",
      "Bash(npx biome*)",
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(rustup *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash*)",
      "Bash(git restore *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Read(/src/**)",
      "Read(/src-tauri/**)",
      "Read(/public/**)",
      "Edit(/src/**)",
      "Edit(/src-tauri/**)",
      "Edit(/public/**)",
      "Edit(/package.json)",
      "Edit(/tsconfig*.json)",
      "Edit(/*.config.*)",
      "Edit(/index.html)",
      "Edit(/.claude/**)",
      "Edit(/AGENTS.md)",
      "Edit(/CLAUDE.md)",
      "Edit(/ARCHITECTURE.md)",
      "Edit(/README.md)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.enc)",
      "Read(**/client_secret*.json)",
      "Read(**/secrets/**)",
      "Edit(.env)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.key)",
      "Edit(**/*.enc)",
      "Edit(**/client_secret*.json)",
      "Edit(**/secrets/**)"
    ]
  },
  "env": {
    "RUST_LOG": "warn"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format.sh"
          }
        ]
      }
    ]
  }
}
